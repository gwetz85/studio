
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Admin ditentukan jika UID ada di koleksi roles_admin 
      // atau email diawali dengan 'admin' atau merupakan akun 'agus'
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email.startsWith("admin@") ||
        request.auth.token.email == "agus@mtnet.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /roles_admin/{adminUid} {
      allow get: if isAdmin();
      allow list, create, update, delete: if false;
    }

    match /servicePackages/{servicePackageId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /psbRequests/{requestId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      // Izinkan pengguna membaca data mereka sendiri untuk pengecekan role
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /issues/{issueId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
