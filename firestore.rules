
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Menambahkan agus@mtnet.com ke dalam aturan keamanan admin
      return isSignedIn() && (
        request.auth.token.email == "admin@mtnet.com" || 
        request.auth.token.email == "agus@mtnet.com" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /roles_admin/{adminUid} {
      allow get: if isAdmin();
      allow list, create, update, delete: if false;
    }

    match /servicePackages/{servicePackageId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /psbRequests/{requestId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    match /issues/{issueId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
