
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Mengizinkan akses baca dan tulis penuh untuk semua koleksi 
    // jika pengguna sudah melakukan login (terautentikasi).
    // Ini menghapus batasan yang menyebabkan error 'Missing or insufficient permissions'.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
  }
}
