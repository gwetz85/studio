
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Fungsi Pembantu ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "agus@mtnet.com" ||
        request.auth.uid == "EdUhRV3odgO5TTzVMPSBAsMFaNP2"
      );
    }

    // --- Aturan Koleksi ---

    // Permintaan User: Koleksi Issues dapat dibaca dan ditulis oleh semua yang login
    match /issues/{document=**} {
      allow read, write: if isSignedIn();
    }

    // Pelanggan, Paket, & Invoices: Read untuk Staff, Write hanya Admin
    match /customers/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /servicePackages/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /invoices/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // PSB: Read/Create untuk Staff, Update/Delete hanya Admin
    match /psbRequests/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Users: Akses mandiri atau Admin penuh
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
