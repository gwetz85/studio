
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "agus@mtnet.com" ||
        request.auth.uid == "EdUhRV3odgO5TTzVMPSBAsMFaNP2" ||
        request.auth.token.email.startsWith("admin@")
      );
    }

    // --- Global Access Rules ---

    // Pelanggan, Paket, Invoices, Issues: Read for all Staff, Write for Admin
    match /customers/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /servicePackages/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /invoices/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // PSB: Create for Staff, Full for Admin
    match /psbRequests/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Users: Self Read/Write, Admin Full
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin() && userId != request.auth.uid;
    }

    // Issues: Read/Write for Staff (except delete), Admin Full
    match /issues/{id} {
      allow read, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
  }
}
