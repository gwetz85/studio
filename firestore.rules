
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        // Prioritas 1: Hardcoded Email Admin Utama
        request.auth.token.email == "agus@mtnet.com" ||
        request.auth.token.email.startsWith("admin@") ||
        // Prioritas 2: Pengecekan Koleksi Role Admin
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        // Prioritas 3: Pengecekan Field Role di Dokumen User
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }

    // --- Collection Rules ---

    match /servicePackages/{servicePackageId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /psbRequests/{requestId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin() && userId != request.auth.uid;
    }

    match /issues/{issueId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
