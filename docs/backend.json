
{
  "entities": {
    "Customer": {
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer of the internet service.",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "packageId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "passive", "inactive"] },
        "modemSnMac": { "type": "string" },
        "createdAt": { "type": "number" },
        "deactivationDate": { "type": "number" }
      },
      "required": ["name", "status", "createdAt"]
    },
    "ServicePackage": {
      "title": "ServicePackage",
      "type": "object",
      "description": "Defines internet service packages.",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "speed": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "speed"]
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "description": "Records monthly payments/invoices.",
      "properties": {
        "customerId": { "type": "string" },
        "amount": { "type": "number" },
        "billingPeriod": { "type": "string" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"] },
        "paymentDate": { "type": "number" }
      },
      "required": ["customerId", "amount", "billingPeriod", "status"]
    },
    "PSBRequest": {
      "title": "PSBRequest",
      "type": "object",
      "description": "Records new installation requests.",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "packageId": { "type": "string" },
        "status": { "type": "string", "enum": ["pasif", "aktif"] },
        "modemSnMac": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "status", "createdAt"]
    },
    "Issue": {
      "title": "Issue",
      "type": "object",
      "description": "Troubleshooting and repair records.",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "reportDescription": { "type": "string" },
        "fixDescription": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "createdAt": { "type": "number" },
        "solvedAt": { "type": "number" },
        "reporter": { "type": "string" }
      },
      "required": ["customerId", "reportDescription", "status", "createdAt"]
    },
    "AppUser": {
      "title": "AppUser",
      "type": "object",
      "description": "System users registered by admin.",
      "properties": {
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "createdAt": { "type": "number" }
      },
      "required": ["username", "role"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/servicePackages/{packageId}": {
      "schema": "#/backend/entities/ServicePackage",
      "description": "Service packages catalog"
    },
    "/customers/{customerId}": {
      "schema": "#/backend/entities/Customer",
      "description": "Customer records"
    },
    "/invoices/{invoiceId}": {
      "schema": "#/backend/entities/Invoice",
      "description": "Payment records"
    },
    "/psbRequests/{requestId}": {
      "schema": "#/backend/entities/PSBRequest",
      "description": "New installation requests"
    },
    "/issues/{issueId}": {
      "schema": "#/backend/entities/Issue",
      "description": "Troubleshooting records"
    },
    "/users/{userId}": {
      "schema": "#/backend/entities/AppUser",
      "description": "User account definitions"
    }
  }
}
